{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "env": {
    "JWT_SECRET": "@jwt_secret",
    "DATABASE_URL": "@database_url",
    "ALLOWED_ORIGINS": "@allowed_origins"
  },
  "functions": {
    "pages/api/**": {
      "maxDuration": 60
    }
  }
}