{
  "name": "tarkeeb-pro-frontend",
  "version": "1.0.0",
  "description": "Tarkeeb Pro Frontend - React Web Application",
  "private": true,
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@hello-pangea/dnd": "^18.0.1",
    "axios": "^1.4.0",
    "date-fns": "^2.29.3",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.43.0",
    "react-hot-toast": "^2.4.0",
    "react-icons": "^4.8.0",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.30.1",
    "tailwindcss": "^3.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.3.7"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.40.0",
    "prettier": "^2.8.8",
    "react-scripts": "^5.0.1"
  },
  "scripts": {
    "prepare:excel-import": "node ../scripts/generate-excel-import-asset.mjs",
    "predev": "npm run prepare:excel-import",
    "prebuild": "npm run prepare:excel-import",
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "start": "react-scripts start",
    "cf:build": "cross-env GENERATE_SOURCEMAP=false npm run build",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:dev": "npm run cf:build && wrangler dev",
    "test": "react-scripts test",
    "lint": "react-scripts test --watchAll=false",
    "format": "prettier --write ."
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
