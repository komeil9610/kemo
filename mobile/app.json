{
  "expo": {
    "name": "Tarkeeb Pro Mobile",
    "slug": "tarkeeb-pro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["android", "ios", "web"],
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f5efe6"
    },
    "android": {
      "package": "com.tarkeebpro.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.tarkeebpro.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "assetBundlePatterns": ["**/*"]
  }
}
