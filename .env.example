# =========================================
# RentIT Environment Variables
# =========================================

# -----------------------------------------
# Cloudflare path (recommended current setup)
# -----------------------------------------

# Frontend local override only.
# On Cloudflare production, the frontend calls /api on the same origin.
REACT_APP_API_URL=http://localhost:8787/api

# Edge API local CORS allow-list
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8787

# Configure this as a Worker secret with Wrangler in production
JWT_SECRET=change_me_for_cloudflare_worker

# Optional helper values for the first admin account
ADMIN_NAME=RentIT Admin
ADMIN_EMAIL=admin@rentit.com
ADMIN_PASSWORD=change_me_in_production

# Optional future integrations
REACT_APP_STRIPE_KEY=your_stripe_public_key

# -----------------------------------------
# Optional Supabase bridge for large datasets / migration
# -----------------------------------------

# Example: https://your-project-ref.supabase.co
SUPABASE_URL=

# Server-side only. Never expose this in the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Optional override for PostgREST schema and chunk size.
SUPABASE_SCHEMA=public
SUPABASE_SYNC_BATCH_SIZE=500

# D1 source used by the sync bridge
D1_DATABASE_NAME=tarkeeb_pro_db
D1_SYNC_REMOTE=true

# -----------------------------------------
# Legacy Node/Express path
# -----------------------------------------

NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rentit_db
JWT_EXPIRE=7d

STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key

EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

FIREBASE_API_KEY=your_firebase_key
FIREBASE_PROJECT_ID=your_firebase_project_id

AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=rentit-bucket

REACT_NATIVE_API_URL=http://your_ip:5000/api
