{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "create-react-app",
  "buildCommand": "GENERATE_SOURCEMAP=false npm --prefix frontend run build",
  "devCommand": "npm --prefix frontend run dev",
  "installCommand": "npm --prefix frontend ci --no-audit --fund=false --loglevel=error && npm --prefix edge-api ci --omit=dev --no-audit --fund=false --loglevel=error",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?path=:path*"
    }
  ]
}
